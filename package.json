{
  "name": "react-native-crossword",
  "version": "0.1.0",
  "description": "A React Native library for building crossword puzzles, powered by Skia, Reanimated & Gesture Handler",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "build": "bob build",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "crossword",
    "puzzle",
    "skia",
    "game",
    "react-native-crossword"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luciaLebrun/react-native-crossword.git"
  },
  "author": "Lucia Lebrun <lucia@example.com> (https://github.com/luciaLebrun)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/luciaLebrun/react-native-crossword/issues"
  },
  "homepage": "https://github.com/luciaLebrun/react-native-crossword#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@shopify/react-native-skia": "^1.12.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "react": "^19.0.0",
    "react-native": "^0.79.0",
    "react-native-builder-bob": "^0.35.0",
    "react-native-gesture-handler": "^2.24.0",
    "react-native-reanimated": "^4.3.0",
    "release-it": "^18.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.79.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "dependencies": {
    "immer": "^10.1.1"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    }
  }
}
