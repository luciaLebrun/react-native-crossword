{
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "react-native-crossword": ["./src/index"]
    },
    "strict": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "lib/typescript",
    "types": ["react"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "example", "src/__tests__"]
}
